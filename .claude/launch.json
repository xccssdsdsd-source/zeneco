{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import http.server, os; http.server.test(HandlerClass=http.server.SimpleHTTPRequestHandler, port=int(os.environ.get('PORT', 8080)))"],
      "port": 8080,
      "autoPort": true
    }
  ]
}
